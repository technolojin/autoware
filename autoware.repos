    version: 139c82ef83e152216cdecbed3e52ffe17d8dffd3
    base: true
  # Include many-nodes-in-container launch fix that ensures no LoadComposableNode call hangs
  # See https://github.com/ros2/launch_ros/compare/humble...tier4:launch_ros:/t4-main
