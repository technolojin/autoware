  rclcpp: # for temporally fix https://github.com/ros2/rclcpp/issues/2163
    type: git
    url: https://github.com/tier4/rclcpp.git
    # This old version is not directly related to the issue, but it is stable.
    version: humble-with-fix-service-connection-patch
  vendor/pyrocan:
    type: git
    url: git@github.com:tier4/pyrocan.git
    version: main
  vendor/dynamic_message_introspection:
