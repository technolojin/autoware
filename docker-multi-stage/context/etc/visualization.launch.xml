<?xml version="1.0" encoding="UTF-8"?>
<launch>
  <arg name="vehicle_model" default="sample_vehicle" description="vehicle model name"/>
  <arg name="use_sim_time" default="false" description="use_sim_time"/>
  <arg name="rviz_config" default="$(find-pkg-share autoware_launch)/rviz/autoware.rviz"/>
  <log message="use_sim_time: $(var use_sim_time)"/>

  <include file="$(find-pkg-share autoware_global_parameter_loader)/launch/global_params.launch.py">
    <arg name="use_sim_time" value="$(var use_sim_time)"/>
    <arg name="vehicle_model" value="$(var vehicle_model)"/>
  </include>
  <node pkg="rviz2" exec="rviz2" args="-d $(var rviz_config) -s $(find-pkg-share autoware_launch)/rviz/image/autoware.png">
    <env name="QT_QPA_PLATFORMTHEME" value="qt5ct"/>
  </node>
</launch>
