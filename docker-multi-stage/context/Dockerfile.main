FROM core-all-build AS universe-common-build
SHELL ["/bin/bash", "-o", "pipefail", "-c"]

RUN --mount=type=bind,source=pkg/rosdep-build-universe-common.txt,target=/autoware/rosdep-build.txt \
    --mount=type=bind,source=pkg/rosdep-pip-build-universe-common.txt,target=/autoware/rosdep-pip-build.txt \
    --mount=type=cache,target=/var/cache/apt,sharing=locked \
  apt-get update \
  && xargs -a /autoware/rosdep-build.txt apt-get install -y --no-install-recommends \
  && apt-get clean && rm -rf /var/lib/apt/lists/* \
  && if [ -s /autoware/rosdep-pip-build.txt ]; then pip install --no-cache-dir -r /autoware/rosdep-pip-build.txt; fi

  # TODO: modify aip_urdf_compiler to not require write access
RUN --mount=type=bind,source=src/universe-common,target=/autoware/src,readwrite \
  source /opt/autoware/setup.bash \
  && mkdir -p /opt/autoware \
  && colcon build --merge-install --install-base /opt/autoware --cmake-args -DCMAKE_BUILD_TYPE=Release -DCMAKE_CXX_FLAGS="-w"

# TODO: Build autoware_launch without dependencies. Split autoware_launch into components.
RUN --mount=type=bind,source=src/launcher,target=/autoware/src \
  source /opt/autoware/setup.bash \
  && mkdir -p /opt/autoware \
  && colcon build --merge-install --install-base /opt/autoware --cmake-args -DCMAKE_BUILD_TYPE=Release -DCMAKE_CXX_FLAGS="-w"

RUN rm -rf /autoware/build /autoware/log

CMD ["/bin/bash"]

