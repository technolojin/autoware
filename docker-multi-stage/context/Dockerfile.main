    --mount=type=bind,source=pkg/rosdep-pip-exec-planning-control.txt,target=/autoware/rosdep-pip-exec-planning-control.txt \
    --mount=type=bind,source=pkg/rosdep-pip-exec-vehicle-system.txt,target=/autoware/rosdep-pip-exec-vehicle-system.txt \
    --mount=type=bind,source=pkg/rosdep-pip-exec-api.txt,target=/autoware/rosdep-pip-exec-api.txt \
    --mount=type=bind,source=pkg/rosdep-pip-exec-visualization.txt,target=/autoware/rosdep-pip-exec-visualization.txt \
    --mount=type=bind,source=pkg/rosdep-pip-exec-simulation.txt,target=/autoware/rosdep-pip-exec-simulation.txt \
    --mount=type=cache,target=/var/cache/apt,sharing=locked \
  apt-get update \
  && xargs -a /autoware/rosdep-exec-localization-mapping.txt apt-get install -y --no-install-recommends \
  && xargs -a /autoware/rosdep-exec-planning-control.txt apt-get install -y --no-install-recommends \
  && xargs -a /autoware/rosdep-exec-vehicle-system.txt apt-get install -y --no-install-recommends \
  && xargs -a /autoware/rosdep-exec-api.txt apt-get install -y --no-install-recommends \
  && xargs -a /autoware/rosdep-exec-visualization.txt apt-get install -y --no-install-recommends \
  && xargs -a /autoware/rosdep-exec-simulation.txt apt-get install -y --no-install-recommends \
  && if [ -s /autoware/rosdep-pip-exec-localization-mapping.txt ]; then pip install --no-cache-dir -r /autoware/rosdep-pip-exec-localization-mapping.txt; fi \
  && if [ -s /autoware/rosdep-pip-exec-planning-control.txt ]; then pip install --no-cache-dir -r /autoware/rosdep-pip-exec-planning-control.txt; fi \
  && if [ -s /autoware/rosdep-pip-exec-vehicle-system.txt ]; then pip install --no-cache-dir -r /autoware/rosdep-pip-exec-vehicle-system.txt; fi \
  && if [ -s /autoware/rosdep-pip-exec-api.txt ]; then pip install --no-cache-dir -r /autoware/rosdep-pip-exec-api.txt; fi \
  && if [ -s /autoware/rosdep-pip-exec-visualization.txt ]; then pip install --no-cache-dir -r /autoware/rosdep-pip-exec-visualization.txt; fi \
  && if [ -s /autoware/rosdep-pip-exec-simulation.txt ]; then pip install --no-cache-dir -r /autoware/rosdep-pip-exec-simulation.txt; fi \
  && apt-get clean && rm -rf /var/lib/apt/lists/*

COPY --from=localization-mapping-build /opt/autoware /opt/autoware
COPY --from=planning-control-build /opt/autoware /opt/autoware
COPY --from=vehicle-system-build /opt/autoware /opt/autoware
COPY --from=api-build /opt/autoware /opt/autoware
COPY --from=visualization-build /opt/autoware /opt/autoware
COPY --from=simulation-build /opt/autoware /opt/autoware

COPY etc/cyclonedds.xml /autoware/dds/cyclonedds.xml
COPY etc/entrypoint.bash /entrypoint.bash
RUN chmod +x /entrypoint.bash

ENTRYPOINT ["/entrypoint.bash"]
CMD ["/bin/bash"]

FROM universe-common-build AS evaluation-build
SHELL ["/bin/bash", "-o", "pipefail", "-c"]

RUN --mount=type=bind,source=pkg/rosdep-build-evaluation.txt,target=/autoware/rosdep-build.txt \
    --mount=type=bind,source=pkg/rosdep-pip-build-evaluation.txt,target=/autoware/rosdep-pip-build.txt \
    --mount=type=cache,target=/var/cache/apt,sharing=locked \
  apt-get update \
  && xargs -a /autoware/rosdep-build.txt apt-get install -y --no-install-recommends \
  && apt-get clean && rm -rf /var/lib/apt/lists/* \
  && if [ -s /autoware/rosdep-pip-build.txt ]; then pip install --no-cache-dir -r /autoware/rosdep-pip-build.txt; fi

RUN --mount=type=bind,source=src/evaluation,target=/autoware/src \
  source /opt/autoware/setup.bash \
  && mkdir -p /opt/autoware \
  && colcon build --merge-install --install-base /opt/autoware --cmake-args -DCMAKE_BUILD_TYPE=Release -DCMAKE_CXX_FLAGS="-w"

CMD ["/bin/bash"]

FROM universe-all AS evaluation
SHELL ["/bin/bash", "-o", "pipefail", "-c"]

RUN --mount=type=bind,source=pkg/rosdep-exec-evaluation.txt,target=/autoware/rosdep-exec.txt \
    --mount=type=bind,source=pkg/rosdep-pip-exec-evaluation.txt,target=/autoware/rosdep-pip-exec.txt \
    --mount=type=cache,target=/var/cache/apt,sharing=locked \
  apt-get update \
  && xargs -a /autoware/rosdep-exec.txt apt-get install -y --no-install-recommends \
  && if [ -s /autoware/rosdep-pip-exec.txt ]; then pip install --no-cache-dir -r /autoware/rosdep-pip-exec.txt; fi \
  && apt-get clean && rm -rf /var/lib/apt/lists/*


COPY --from=evaluation-build /opt/autoware /opt/autoware

# Workaround for CI requiring install path suffix
RUN source /opt/autoware/setup.bash && colcon build && rm -rf build log

COPY etc/entrypoint.bash /entrypoint.bash
RUN chmod +x /entrypoint.bash

ENTRYPOINT ["/entrypoint.bash"]
CMD ["/bin/bash"]
