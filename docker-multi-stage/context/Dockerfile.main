# hadolint global ignore=SC1091,DL3006,DL3013
# cSpell: ignore readwrite
ARG BASE_IMAGE_RUNTIME=pilot-auto:base-image-runtime
ARG BASE_IMAGE_BUILD=pilot-auto:base-image-build



FROM $BASE_IMAGE_BUILD AS tier4-ros-build
SHELL ["/bin/bash", "-o", "pipefail", "-c"]
ARG ROS_DISTRO

RUN --mount=type=bind,source=pkg/rosdep-build-tier4-ros.txt,target=/autoware/rosdep-build.txt \
    --mount=type=bind,source=pkg/rosdep-pip-build-tier4-ros.txt,target=/autoware/rosdep-pip-build.txt \
    --mount=type=cache,target=/var/cache/apt,sharing=locked \
  apt-get update \
  && xargs -a /autoware/rosdep-build.txt apt-get install -y --no-install-recommends \
  && apt-get clean && rm -rf /var/lib/apt/lists/* \
  && if [ -s /autoware/rosdep-pip-build.txt ]; then pip install --no-cache-dir -r /autoware/rosdep-pip-build.txt; fi

RUN --mount=type=bind,source=src/tier4-ros,target=/autoware/src \
  source /opt/ros/$ROS_DISTRO/setup.bash \
  && mkdir -p /opt/autoware \
  && colcon build --merge-install --install-base /opt/autoware --cmake-args -DCMAKE_BUILD_TYPE=Release -DCMAKE_CXX_FLAGS="-w"

CMD ["/bin/bash"]

FROM $BASE_IMAGE_RUNTIME AS tier4-ros
SHELL ["/bin/bash", "-o", "pipefail", "-c"]

RUN --mount=type=bind,source=pkg/rosdep-exec-tier4-ros.txt,target=/autoware/rosdep-exec.txt \
    --mount=type=bind,source=pkg/rosdep-pip-exec-tier4-ros.txt,target=/autoware/rosdep-pip-exec.txt \
    --mount=type=cache,target=/var/cache/apt,sharing=locked \
  apt-get update \
  && xargs -a /autoware/rosdep-exec.txt apt-get install -y --no-install-recommends \
  && if [ -s /autoware/rosdep-pip-exec.txt ]; then pip install --no-cache-dir -r /autoware/rosdep-pip-exec.txt; fi \
  && apt-get clean && rm -rf /var/lib/apt/lists/*

COPY --from=tier4-ros-build /opt/autoware /opt/autoware

CMD ["/bin/bash"]



