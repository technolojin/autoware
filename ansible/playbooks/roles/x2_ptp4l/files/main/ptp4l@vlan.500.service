[Unit]
Description=PTPv2 for synchronizing main and other ECUs
After=network-online.target

[Service]
Type=simple
ExecStart=/usr/sbin/ptp4l -i vlan.500 -m -S -A --uds_address=/var/run/ptp4l@vlan.500
ExecStop=/bin/kill -TERM $MAINPID
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target network-online.target
