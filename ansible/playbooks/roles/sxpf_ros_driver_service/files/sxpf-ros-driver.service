# cspell: ignore sxpf Solectrix
[Unit]
Description=Solectrix proFRAME ROS driver service
After=network-online.target

[Service]
Restart=always
ExecStart=/opt/autoware/services/sxpf-ros-driver-service/run.sh
RestartSec=5
Environment="HOME=root"
KillSignal=SIGINT
SyslogIdentifier=sxpf-ros-driver

[Install]
WantedBy=multi-user.target network-online.target
