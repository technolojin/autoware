
<?xml version="1.0" encoding="UTF-8"?>
<CycloneDDS xmlns="https://cdds.io/config" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://cdds.io/config https://raw.githubusercontent.com/eclipse-cyclonedds/cyclonedds/master/etc/cyclonedds.xsd">
  <Domain id="any">
    <General>
      <NetworkInterfaceAddress>{{ x2_cyclonedds_for_redundancy_cyclonedds.network_interface | map(attribute='address') | join(',') }}</NetworkInterfaceAddress>
      <AllowMulticast>spdp</AllowMulticast>
      <MaxMessageSize>65500B</MaxMessageSize>
      <FragmentSize>4000B</FragmentSize>
      <DontRoute>true</DontRoute>
    </General>
    <Internal>
      <MinimumSocketReceiveBufferSize>{{ x2_cyclonedds_for_redundancy_cyclonedds.minimum_socket_receive_buffer_size }}</MinimumSocketReceiveBufferSize>
    </Internal>
  </Domain>
</CycloneDDS>
