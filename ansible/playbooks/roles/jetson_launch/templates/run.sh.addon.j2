#!/bin/bash

source {{ autoware_env_dir }}/autoware.env && true
source {{ autoware_env_dir }}/vehicle.env

# get installed ros distro
# shellcheck disable=SC2012
ROS_DISTRO=$(ls -1 /opt/ros | head -1)

source /opt/ros/${ROS_DISTRO}/setup.bash
source {{ autoware_install_dir }}/install/setup.bash

{% if fool_proof_check | bool %}
source /opt/autoware/services/fool-proof-check/activate_call_diag.sh
{% endif %}

if [ "$VEHICLE_MODEL" == "j6_gen2" ]; then
    while [[ ! -e /var/run/enp7s0-ready ]]; do
        {% if fool_proof_check | bool %}
        call_diag_polling --status "Error" \
                --mrm_name_suffix enp7s0-ready \
                --event_id "Network Interface Error" \
                --message "/var/run/enp7s0-ready is not found" \
                --impact "Ethernet communication unavailable"
        {% endif %}
        sleep 1
    done
    {% if fool_proof_check | bool %}
    call_diag_polling --status "Ok" \
            --mrm_name_suffix enp7s0-ready \
            --event_id "none" \
            --message "none" \
            --impact "none"
    {% endif %}
fi

# for letterbox_monitor
mkdir -p /home/autoware/.ros/recognition_log
export ROS_LOG_DIR=/home/autoware/.ros/recognition_log

ros2 launch edge_auto_jetson_launch edge_auto_jetson.launch.xml
