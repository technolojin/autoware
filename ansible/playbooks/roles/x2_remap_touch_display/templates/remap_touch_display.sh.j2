#!/usr/bin/env bash
# cSpell:ignore prereqs endraw RLENGTH RSTART mapfile EDID
###############################################################################
# Touch screen setup Xorg + MPX
#
# Steps
# -----
# 0. Wait until both the target window ($APP_TITLE) and at least one
#    eGalaxTouch device appear (RETRIES x DELAY).
# 1. Identify the 1024x768 touch output (preferring missing EDID panels) and
#    the widest remaining monitor. Layout: touch (0,0) primary, normal (1024,768).
# 2. Create / reuse an extra master pointer ($MPX_NAME) and attach + remap all
#    eGalaxTouch devices to the touch output.
# 3. Resize the target window to full screen on the touch panel.
###############################################################################
set -euo pipefail

# Config
TOUCH_DISPLAY="{{ x2_touch_display_name }}"   # substring to match touch devices
APP_TITLE="{{ x2_touch_app_name }}"            # window title to move
TOUCH_RES="{{ x2_touch_display_resolution }}" # native resolution (e.g. 1024x768)
MPX_NAME="{{ x2_mpx_name }}"                  # new master pointer name
RETRIES=20 DELAY=5                             # retry count / seconds

export DISPLAY=${DISPLAY:-:0}
export XAUTHORITY=${XAUTHORITY:-"$HOME/.Xauthority"}

die(){ echo "ERROR: $*" >&2; exit 1; }

# Return all connected outputs once
get_outputs(){ xrandr | awk '/ connected/{print $1,$0}'; }

# Touch output: prefer line with 0 mm x 0 mm + resolution, else first resolution match
detect_touch(){
  while IFS= read -r l; do [[ $l == *"$TOUCH_RES"* && $l == *" 0mm x 0mm"* ]] && echo "${l%% *}" && return; done < <(xrandr)
  while IFS= read -r l; do [[ $l == *"$TOUCH_RES"* ]] && echo "${l%% *}" && return; done < <(xrandr)
  return 1
}

# Detect the widest display output that is not the touch panel
detect_main() {
  local t=$1  # touch output to exclude

  get_outputs | awk -v t="$t" '
    $1 != t && match($0, /([0-9]+)x/) {
      w = substr($0, RSTART, RLENGTH)       # extract width from resolution
      sub(/x.*/, "", w)                     # remove "x..." part to get width only
      if (w > m) { m = w; o = $1 }          # keep the widest one
    }
    END { print o }                         # output the name of the widest display
  '
}

# Ensure extra master pointer exists
create_mpx(){ xinput --list | grep -q "$MPX_NAME pointer" || xinput create-master "$MPX_NAME"; }

# Attach all matching touch devices to the new master and map them to the panel
{% raw %}
attach_touch() {
  local out=$1  # target display name

  # Get IDs of devices matching the touch device name
  mapfile -t ids < <(
    xinput --list --id-only | while read -r id; do
      xinput --list-props "$id" 2>/dev/null | grep -q "$TOUCH_DISPLAY" && echo "$id"
    done
  )

  # Abort if no matching devices found
  [[ ${#ids[@]} -gt 0 ]] || die "No device containing '$TOUCH_DISPLAY' found"

  # Reattach and map each device to the target display
  for id in "${ids[@]}"; do
    xinput reattach "$id" "$MPX_NAME pointer"
    xinput map-to-output "$id" "$out"
  done

  echo "Attached ${#ids[@]} device(s) to $out"
}

# Move the target window to (0,0) full screen on the touch panel
move_window(){
  local w h; IFS=x read -r w h <<<"$TOUCH_RES"
  local win=$(wmctrl -lx | awk -v t="$APP_TITLE" '$0~t{print $1;exit}') || true
  [[ -n $win ]] || die "Window '$APP_TITLE' disappeared"
  wmctrl -i -r "$win" -e "0,0,0,$w,$h"

  # rviz2
  local win_rviz=$(wmctrl -lx | awk -v t="rviz2" '$0~t{print $1;exit}') || true
  if [[ -n $win_rviz ]]; then
    wmctrl -i -r "$win_rviz" -e "0,$w,$h,-1,-1"
  else
    echo "rviz window not found"
  fi

  echo "Moved window id $win to 0,0 size ${w}x${h}"
}

# Wait until APP_TITLE window and TOUCH_DISPLAY device are available
wait_for_app_and_device() {
  for ((i=1; i<=RETRIES; i++)); do
    wmctrl -lx | grep -q "$APP_TITLE" && xinput --list | grep -q "$TOUCH_DISPLAY" && return 0
    echo "[$i/$RETRIES] App or touch device not ready, retrying in ${DELAY}s..."
    sleep "$DELAY"
  done
  die "App or touch device not found after $RETRIES attempts"
}

# Wait until at least two displays are connected and they have valid EDID
wait_for_displays_with_edid() {
  for ((i=1; i<=RETRIES; i++)); do
    mapfile -t connected_ports < <(xrandr | awk '/ connected/ {print $1}')
    display_count=${#connected_ports[@]}

    has_size_count=0
    has_size_0_count=0
    for port in "${connected_ports[@]}"; do
      size=$(xrandr | grep "^$port connected" | grep -oP '\d+mm x \d+mm' | head -n1 | xargs) || true
      if [[ -n "$size" && "$size" != "0mm x 0mm" ]]; then
        has_size_count=$((has_size_count + 1))
      elif [[ -n "$size" && "$size" == "0mm x 0mm" ]]; then
        has_size_0_count=$((has_size_0_count + 1))
      fi
    done

    if [[ $display_count -ge 2 && $has_size_count -ge 1 && $has_size_0_count -ge 1 ]]; then
      return 0
    fi

    echo "[$i/$RETRIES] Display EDID check failed, retrying in ${DELAY}s..."

    # Try to re-enable displays
    if [[ $has_size_count -lt 1 || $has_size_0_count -lt 1 ]]; then
      echo "  -> Trying to re-enable displays via xrandr --auto"
      xrandr_cmd="xrandr"
      for port in "${connected_ports[@]}"; do
        xrandr_cmd+=" --output $port --auto"
      done
      eval "$xrandr_cmd"
    fi

    sleep "$DELAY"
  done
  die "EDID-capable display not found after $RETRIES attempts"
}

main(){
  # 0. Unified retry loop wait until both window and devices are present
  wait_for_app_and_device
  wait_for_displays_with_edid
  echo "Application ($APP_TITLE) and touch devices ($TOUCH_DISPLAY) are present, proceeding with setup..."

  # 1. Detect outputs
  local touch_out=$(detect_touch) || die "Touch output not found"
  local main_out=$(detect_main "$touch_out") || die "Main output not found"

  echo "Touch display: $touch_out"
  echo "Normal display: $main_out"

  # 2. Arrange layout: touch=(0,0), normal=(1024,768)
  local tw th; IFS=x read -r tw th <<<"$TOUCH_RES"
  xrandr --output "$touch_out" --mode "$TOUCH_RES" --pos 0x0 --primary \
         --output "$main_out" --mode 1920x1080 --pos "${tw}x${th}"
  sleep 3

  # 3. MPX pointer setup + remap
  create_mpx
  attach_touch "$touch_out"

  # 4. Move application window
  move_window

  echo "=== Setup complete ==="
}

main "$@"
{% endraw %}
