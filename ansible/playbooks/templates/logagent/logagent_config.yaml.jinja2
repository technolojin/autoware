# cspell: ignore kdump coredump logagent Logagent
# Logagent configurations ------------------------------------------------------------------------
# use webauto vehicle info
use_webauto_agent: true
vehicle_id: ""
project_id: ""
diag_ok_state: [running]
# group_id: ""
# custom_tags:
#   event: test
#   test_no: "1"
# Mob Proxy ---------------------------------------------------------------------------------------
mob_proxy:
  address: ["{{ logagent_mob_proxy_address }}"]
# Directories -------------------------------------------------------------------------------------
directories:
  - output_at: "{{ logagent_rosbag_logging_directory }}"
    output_mountpoint: "{{ logagent_rosbag_logging_directory_mountpoint }}"
  - output_at: "{{ logagent_temporary_logging_directory }}"
    output_mountpoint: {{ logagent_temporary_logging_directory_mountpoint }}"
