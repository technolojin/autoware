# cspell: ignore kdump coredump logagent Logagent
# <Logagent configurations> ----------------------------------------------------------------------
# <use webauto vehicle info>
use_webauto_agent: true
vehicle_id: ""
project_id: ""
diag_ok_state: [running]
group_id: "x2dev"
# custom_tags:
#   event: test
#   test_no: "1"
# <Mob Proxy> -------------------------------------------------------------------------------------
mob_proxy:
  address: [{{ logagent_mob_proxy_address }}]
# <Directories> -----------------------------------------------------------------------------------
directories:
  - output_at: "{{ logagent_rosbag_logging_directory }}"
    output_mountpoint: "{{ logagent_rosbag_logging_directory_mountpoint }}"
# <streaming configurations> ----------------------------------------------------------------------
streaming:
  # <ros topics> --------------------------------------
  #ros_topic:
    # ros domains
    #- domain_name: main
      #topics:
        #- topic_name: /system/fail_safe/mrm_state
          #topic_type: autoware_adapi_V1_msgs/msg/MrmState
  # <syslog streaming> --------------------------------
  syslog:
    # ros severity override syslog priority. (FATAL -> emergency, alert, critical)
    ros_fatal_priority: alert
    # <syslog priority level> [emergency critical alert error warning info debug]
    rsyslog_priority: {{ logagent_rsyslog_priority }}
    rsyslog_config_template: "{{ logagent_rsyslog_config_template }}"
    rsyslog_port: {{ logagent_rsyslog_port }}
    rsyslog_pipe_file: {{ logagent_rsyslog_pipe_file }}
    hosts:
      - host_name: main
        priority: warning
      - host_name: logging
        priority: warning
      - host_name: sub
        priority: warning
      - host_name: perception1
        priority: warning
      - host_name: perception2
        priority: warning
      - host_name: voice-system
        priority: warning
      - host_name: signage
        priority: warning
      # - host_name: ms1
      #   priority: warning
      # - host_name: ms2
      #   priority: warning
      # - host_name: addon
      #   priority: warning
# <file upload configurations> --------------------------------------------------------------------
log_upload:
  upload_logs:
    # - file_type: rosbag
    #   extensions: [db3]
    #   base_path: "{{ logagent_rosbag_logging_directory }}"
    #   domain_names: []
    #   except_current: true
    - file_type: syslog
      extensions: [log]
      base_path: "{{ logagent_rosbag_logging_directory }}"
      hosts: []
      except_current: true
