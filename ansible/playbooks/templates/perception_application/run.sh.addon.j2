#!/bin/bash

source {{ autoware_env_dir }}/autoware.env && true
source {{ autoware_env_dir }}/vehicle.env

source /opt/ros/humble/setup.bash
source {{ perception_application_base_path }}/overlay_ws/install/setup.bash

# for letterbox_monitor
mkdir -p {{ perception_application_base_path }}/.ros/recognition_log
export ROS_LOG_DIR={{ perception_application_base_path }}/.ros/recognition_log

ros2 launch edge_auto_jetson_launch edge_auto_jetson.launch.xml
