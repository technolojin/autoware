[general]
use-webauto-agent=yes
vehicle-id=
project-id=
environment-id=
map-version-id=
output-at={{ rosbag_logging_directory }}
disk-type=internal
rosbridge-host={{ rosbridge_host }}
rosbridge-port={{ rosbridge_port }}
setup-shell=/opt/autoware/services/set-autoware-env/setup.sh
ros-domain-id={{ ros_domain_id }}
rmw-implementation=rmw_cyclonedds_cpp
recording-type=manual
recording-mode-values=True
diag-ok-state=ready,recording
initial-state=recording
disk-threshold-warning=30
disk-threshold-error=10
upload-dist=aws
recorder=ros2bag

[rosbag]
topic-list-type=allowlist
topic-list=
