# cspell: ignore logfile systemlog kdump

# Logpacker configurations ------------------------------------------------------------------------
# use webauto vehicle info
use_webauto_agent: true
vehicle_id: ""
project_id: ""
environment_id: ""
map_version_id: ""
# env file list
env_file_paths:
  - /home/autoware/vehicle.env
  - /root/vehicle.env
upload_dist: aws
diag_ok_state:
  - initial
  - wait_webauto
  - ready
  - running
# use old setting json filename (rosbag -> bagpacker)
use_old_name: true
# output directories list
directories:
  - output_at: "{{ rosbag_logging_directory }}"
    output_mountpoint: "{{ rosbag_logging_directory_mountpoint }}"
    disk_threshold_error: 10
    disk_threshold_warning: 30

# -------------------------------------------------------------------------------------------------
# logging mode configurations
# -------------------------------------------------------------------------------------------------
logging_mode:
  # logging mode list
  mode_list:
    - always
    - event
  # default logging mode
  default_mode: always
  # logging mode for operation mode
  operation_mode: event
  # current logging mode file path
  current_mode_file: "{{ logpacker_config_dir }}/logging_mode"
  # always mode configurations --------------------------------------------------------------------
  always:
    packer:
      upload_dist: aws
    # plugin enables
    enable_plugins:
      - rosbag
      # - rotation
      - syslog
      - coredump
      # - kdump
      # - tcpdump

# -------------------------------------------------------------------------------------------------
