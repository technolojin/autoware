# -------------------------------------------------------------------------------------------------
# syslog plugin configurations
# -------------------------------------------------------------------------------------------------
syslog:
  # If you use another file for syslog configuration, define its file path.
  # When not defined, this file will be used.
  # params_file: "{{ logpacker_config_dir }}/syslog_params.yaml"
  unified_logs: true
  # expire_days: -1
  # keep_config: true
  initial_logfile_path: "/tmp/syslog"
  rsyslog:
    config_file: "{{ rsyslog_config_file }}"
    config_template: "{{ logpacker_config_dir }}/systemlog.conf.server.template"
    storage_filters:
      - "*.*"
    server: true
    server_port: 514
    tcp_enable: true
    udp_enable: false
    allowed_sender:
      - "127.0.0.1"
  output_at: "{{ rosbag_logging_directory }}"

# -------------------------------------------------------------------------------------------------
# coredump plugin configurations
# -------------------------------------------------------------------------------------------------
coredump:
  # If you use the other file for the coredump configuration, define its file path.
  # params_file: /etc/logging_system/logpacker/coredump_params.yaml
  log_directory_path: "/var/lib/systemd/coredump"
  output_at: "{{ rosbag_logging_directory }}"

# -------------------------------------------------------------------------------------------------
# kdump plugin configurations
# -------------------------------------------------------------------------------------------------
kdump:
  # If you use the other file for the kdump configuration, define its file path.
  # params_file: "{{ logpacker_config_dir }}/kdump_params.yaml"
  log_directory_path: "/var/crash"
  output_at: "{{ rosbag_logging_directory }}"

# -------------------------------------------------------------------------------------------------
# tcpdump plugin configurations (optional)
# -------------------------------------------------------------------------------------------------
# If this configuration is not exist, tcpdump plugin will be disabled.
tcpdump:
  # If you use the other file for the tcpdump configuration, define its file path.
  # params_file: /etc/logging_system/logpacker/tcpdump_params.yaml
  # output_file: ""             # -> use default
  interface: eth0
  # command: /usr/sbin/tcpdump  # -> use default
  # kill_command: /usr/bin/kill # -> use default
  cycle: 60
  output_at: /media/autoware/ROSBAG
  # diag_ok_state:
  #   - initial
  #   - ready
  #   - recording

# -------------------------------------------------------------------------------------------------
# rotation plugin configurations (optional)
# -------------------------------------------------------------------------------------------------
# If this configuration is not exist, rotation plugin will be disabled.
rotation:
  count_limit: 15
  space_limit: 10
  days_limit: 3
  check_cycle: 1
  target_dir: /media/autoware/ROSBAG
  # diag_ok_state:
  #   - initial
  #   - ready
  #   - recording
