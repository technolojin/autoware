# -------------------------------------------------------------------------------------------------
# syslog plugin configurations
# -------------------------------------------------------------------------------------------------
syslog:
  # If you use another file for syslog configuration, define its file path.
  # When not defined, this file will be used.
  # params_file: "{{ logpacker_config_dir }}/syslog_params.yaml"
  unified_logs: true
  # expire_days: -1
  # keep_config: true
  initial_logfile_path: "/tmp/syslog"
  rsyslog:
    config_file: "{{ rsyslog_config_file }}"
    config_template: "{{ logpacker_config_dir }}/systemlog.conf.server.template"
    storage_filters:
      - "*.*"
    server: true
    server_port: 514
    tcp_enable: true
    udp_enable: false
    allowed_sender:
      - "127.0.0.1"
      - "192.168.10.0/24"
      - "192.168.20.0/24"
      - "192.168.30.0/24"
  output_at: "{{ rosbag_logging_directory }}"
# -------------------------------------------------------------------------------------------------
# coredump plugin configurations
# -------------------------------------------------------------------------------------------------
coredump:
  # If you use the other file for the coredump configuration, define its file path.
  # params_file: /etc/logging_system/logpacker/coredump_params.yaml
  hosts:
    - host_name: autoware
      ip_addr: 192.168.30.11
      rsync_module: export
      # If 'host_name' and 'ip_addr are empty, it means local host.
      # Local host needs log_dir_path, instead of 'rsync_module'.
      # log_dir_path: /var/lib/systemd/coredump
      options:
        - "-auv"
    - host_name: sub
      ip_addr: 192.168.20.21
      rsync_module: export
      # If 'host_name' and 'ip_addr are empty, it means local host.
      # Local host needs log_dir_path, instead of 'rsync_module'.
      # log_dir_path: /var/lib/systemd/coredump
      options:
        - "-auv"
    - host_name: perception1
      ip_addr: 192.168.30.31
      rsync_module: export
      # If 'host_name' and 'ip_addr are empty, it means local host.
      # Local host needs log_dir_path, instead of 'rsync_module'.
      # log_dir_path: /var/lib/systemd/coredump
      options:
        - "-auv"
    - host_name: perception2
      ip_addr: 192.168.30.32
      rsync_module: export
      # If 'host_name' and 'ip_addr are empty, it means local host.
      # Local host needs log_dir_path, instead of 'rsync_module'.
      # log_dir_path: /var/lib/systemd/coredump
      options:
        - "-auv"
    # Addon or Addon Lite
    - host_name: perception3
      ip_addr: 192.168.30.33
      rsync_module: export
      # If 'host_name' and 'ip_addr are empty, it means local host.
      # Local host needs log_dir_path, instead of 'rsync_module'.
      # log_dir_path: /var/lib/systemd/coredump
      options:
        - "-auv"
  output_at: "{{ rosbag_logging_directory }}"
# -------------------------------------------------------------------------------------------------
# kdump plugin configurations
# -------------------------------------------------------------------------------------------------
kdump:
  hosts:
    - host_name: autoware
      ip_addr: 192.168.30.11
      rsync_module: kdump
      options:
        - "-auv"
        - "--include=[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]/***"
        - "--exclude=*"
    - host_name: sub
      ip_addr: 192.168.20.21
      rsync_module: kdump
      options:
        - "-auv"
        - "--include=[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]/***"
        - "--exclude=*"
    - host_name: perception1
      ip_addr: 192.168.30.31
      rsync_module: kdump
      options:
        - "-auv"
        - "--include=[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]/***"
        - "--exclude=*"
    - host_name: perception2
      ip_addr: 192.168.30.32
      rsync_module: kdump
      options:
        - "-auv"
        - "--include=[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]/***"
        - "--exclude=*"
    - host_name: perception3
      ip_addr: 192.168.30.33
      rsync_module: export
      options:
        - "-auv"
        - "--include=[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]/***"
        - "--exclude=*"
  output_at: "{{ rosbag_logging_directory }}"
rotation:
  count_limit: 0
  space_limit: 10
  days_limit: 0
  target_dir: "{{ temporary_logging_directory }}"
  check_cycle: 1
# -------------------------------------------------------------------------------------------------
# logging mode configurations
# -------------------------------------------------------------------------------------------------
logging_mode:
  mode_list:
    - "always"
    - "event"
    - "light"
  default_mode: "always"
  operation_mode: "event"
  current_mode_file: "{{ logpacker_config_dir }}/logging_mode"
  # always mode configurations --------------------------------------------------------------------
  always:
    packer:
      upload_dist: "aws"
    enable_plugins:
      - rosbag
      - syslog
      - coredump
      # - kdump
      # - tcpdump
      # - rotation
    rosbag:
      initial_state: "ready"
      output_at: "{{ rosbag_logging_directory }}"
      # qos_profile_overrides_path: "{{ logpacker_config_dir }}/qos_profile_overrides.yaml"
      recording_type: "manual"
      recording_mode_values:
        - ""
  # event mode configurations ---------------------------------------------------------------------
  event:
    packer:
      upload_dist: "aws"
    enable_plugins:
      - rosbag
      - rotation
      - syslog
      - coredump
      - kdump
      # - tcpdump
      # - rotation
    rosbag:
      output_at: "{{ temporary_logging_directory }}"
      recording_type: "auto"
      initial_state: "recording"
      # qos_profile_overrides_path: "{{ logpacker_config_dir }}/qos_profile_overrides.yaml"
      recording_mode_values:
        - "InitializingVehicle"
        - "WaitingForRoute"
        - "Planning"
        - "WaitingForEngage"
        - "Driving"
        - "ArrivedGoal"
        - "Emergency"
        - "Finalizing"
    rotation:
      target_dir: "{{ temporary_logging_directory }}"
  light:
    enable_plugins:
      - rosbag
      - syslog
      - coredump
      - kdump
    rosbag:
      output_at: "{{ rosbag_logging_directory }}"
      recording_type: "manual"
      recording_mode_values:
        - ""
      topic_list:
        - "/autoware/(.*)"
