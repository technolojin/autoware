# cspell: ignore logfile systemlog kdump coredump

use_webauto_agent: true
vehicle_id: ""
project_id: ""
environment_id: ""
map_version_id: ""
env_file_paths:
  - "/home/autoware/vehicle.env"
  - "/root/vehicle.env"
upload_dist: "aws"
use_old_name: true
directories:
  - output_at: "{{ rosbag_logging_directory }}"
    output_mountpoint: "{{ rosbag_logging_directory_mountpoint }}"
    disk_threshold_error: 1
    disk_threshold_warning: 5
  - output_at: "{{ temporary_logging_directory }}"
    output_mountpoint: "/mnt/TMP"
    disk_threshold_error: 1
    disk_threshold_warning: 5
