use_webauto_agent: true
vehicle_id: ""
project_id: ""
environment_id: ""
map_version_id: ""
env_file_paths:
  - "/home/autoware/vehicle.env"
  - "/root/vehicle.env"
upload_dest: "aws"
use_old_name: true
directories:
  - output_at: "{{ rosbag_logging_directory }}"
    output_mountpoint: "{{ rosbag_logging_directory_mountpoint }}"
    disk_threshold_error: 10
    disk_threshold_warning: 30
  - output_at: "{{ temporary_logging_directory }}"
    disk_threshold_error: 10
    disk_threshold_warning: 30
logging_mode:
  mode_list:
    - always
    - event
    - light
  default_mode: always
  operation_mode: event
  current_mode_file: /etc/autoware_logging_suite/logpacker/logging_mode
  always:
    enable_plugins:
      - rosbag
      - syslog
      - coredump
      - kdump
    rosbag:
      output_at: "{{ rosbag_logging_directory }}"
      recording_type: "manual"
      recording_mode_values:
        - ""
  event:
    enable_plugins:
      - rosbag
      - rotation
      - syslog
      - coredump
      - kdump
    rosbag:
      output_at: "{{ temporary_logging_directory }}"
      recording_type: "auto"
      recording_mode_values:
        - "InitializingVehicle"
        - "WaitingForRoute"
        - "Planning"
        - "WaitingForEngage"
        - "Driving"
        - "ArrivedGoal"
        - "Emergency"
        - "Finalizing"
    rotation:
      target_dir: "{{ temporary_logging_directory }}"
  light:
    enable_plugins:
      - rosbag
      - syslog
      - coredump
      - kdump
    rosbag:
      output_at: "{{ rosbag_logging_directory }}"
      recording_type: "manual"
      recording_mode_values:
        - ""
      topic_list:
        - "/autoware/(.*)"
rosbag:
  # If you use another file for rosbag configuration, define its file path. When not defined, this file will be used.
  # params_file: "{{ logpacker_config_dir }}/rosbag_params.yaml"
  recording_type: "manual"
  recording_mode_values:
    - "Planning"
    - "WaitingForEngage"
    - "Driving"
    - "Emergency"
    - "ArrivedGoal"
  initial_state: "ready"
  diag_ok_state:
    - "ready"
    - "recording"
  topic_list_type: "allowlist"
  topic_list:
    - "(.*)/cooperate_status/(.*)"
    - "(.*)/debug/cyclic_time_ms$"
    - "(.*)/processing_time_ms$"
    - "(.*)/metrics$"
