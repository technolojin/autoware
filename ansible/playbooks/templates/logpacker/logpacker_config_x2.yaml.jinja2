    - "/webauto/vehicle_info$"
  split_type: "duration"
  split_size: 1024
  split_duration: "60"
  max_cache_size: 104857600
  max_splits: -1
  max_splits_check_cycle: 1
  qos_profile_overrides_path: "{{ logpacker_config_dir }}/qos_profile_overrides.yaml"
  output_at: "{{ rosbag_logging_directory }}"
  exec_reindex: false
syslog:
  # If you use another file for syslog configuration, define its file path. When not defined, this file will be used.
  # params_file: "{{ logpacker_config_dir }}/syslog_params.yaml"
  unified_logs: true
  # expire_days: -1
  # keep_config: true
  initial_logfile_path: "/tmp/syslog"
  rsyslog:
    config_file: "{{ rsyslog_config_file }}"
    config_template: "{{ logpacker_config_dir }}/systemlog.conf.server.template"
    storage_filters:
      - "*.*"
    server: true
    server_port: 514
    tcp_enable: true
    udp_enable: false
    allowed_sender:
      - "127.0.0.1"
      - "192.168.10.0/24"
      - "192.168.20.0/24"
      - "192.168.30.0/24"
  output_at: "{{ rosbag_logging_directory }}"
# -------------------------------------------------------------------------------------------------
# coredump plugin configurations
# -------------------------------------------------------------------------------------------------
coredump:
  # If you use the other file for the coredump configuration, define its file path.
  # params_file: /etc/logging_system/logpacker/coredump_params.yaml
  # log_directory_path: "/var/lib/systemd/coredump"
  hosts:
    - host_name: autoware
      ip_addr: 192.168.20.11
      rsync_module: export
      # If 'host_name' and 'ip_addr are empty, it means local host.
      # Local host needs log_dir_path, instead of 'rsync_module'.
      # log_dir_path: /var/lib/systemd/coredump
      options:
        - "-auv"
    - host_name: perception1
      ip_addr: 192.168.20.31
      rsync_module: export
      # If 'host_name' and 'ip_addr are empty, it means local host.
      # Local host needs log_dir_path, instead of 'rsync_module'.
      # log_dir_path: /var/lib/systemd/coredump
      options:
        - "-auv"
    - host_name: perception2
      ip_addr: 192.168.20.32
      rsync_module: export
      # If 'host_name' and 'ip_addr are empty, it means local host.
      # Local host needs log_dir_path, instead of 'rsync_module'.
      # log_dir_path: /var/lib/systemd/coredump
      options:
        - "-auv"
  output_at: "{{ rosbag_logging_directory }}"
# -------------------------------------------------------------------------------------------------
# kdump plugin configurations
# -------------------------------------------------------------------------------------------------
kdump:
  # If you use the other file for the kdump configuration, define its file path.
  # params_file: "{{ logpacker_config_dir }}/kdump_params.yaml"
  log_directory_path: "/var/crash"
  output_at: "{{ rosbag_logging_directory }}"
rotation:
  count_limit: 0
  space_limit: 10
  days_limit: 0
  target_dir: "{{ temporary_logging_directory }}"
  check_cycle: 1
